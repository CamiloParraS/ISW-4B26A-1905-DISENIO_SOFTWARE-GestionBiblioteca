{
  "info": {
    "name": "Biblioteca API",
    "description": "Collection to test the Biblioteca API backend. Set ejemplarId to an existing ejemplar id before running préstamo requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "libroId",
      "value": "",
      "type": "string"
    },
    {
      "key": "usuarioId",
      "value": "",
      "type": "string"
    },
    {
      "key": "prestamoId",
      "value": "",
      "type": "string"
    },
    {
      "key": "ejemplarId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Prueba 1: Crear un libro",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"isbn\": \"978-0-13-468599-1\",\n  \"titulo\": \"Clean Code\",\n  \"autor\": \"Robert C. Martin\",\n  \"anioPublicacion\": 2008,\n  \"categoria\": \"Programación\"\n}"
        },
        "event": [
          {
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "if (pm.response.code === 201) {",
                "  const response = pm.response.json();",
                "  if (response && response.id) {",
                "    pm.collectionVariables.set('libroId', response.id);",
                "  }",
                "}"
              ]
            }
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/libros",
          "host": ["{{baseUrl}}"],
          "path": ["api", "libros"]
        }
      }
    },
    {
      "name": "Prueba 2: Listar todos los libros",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/libros",
          "host": ["{{baseUrl}}"],
          "path": ["api", "libros"]
        }
      }
    },
    {
      "name": "Prueba 3: Consultar un libro por ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/libros/{{libroId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "libros", "{{libroId}}"]
        }
      }
    },
    {
      "name": "Prueba 4: Actualizar un libro",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"isbn\": \"978-0-13-468599-1\",\n  \"titulo\": \"Clean Code: A Handbook of Agile Software Craftsmanship\",\n  \"autor\": \"Robert C. Martin\",\n  \"anioPublicacion\": 2008,\n  \"categoria\": \"Ingeniería de Software\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/libros/{{libroId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "libros", "{{libroId}}"]
        }
      }
    },
    {
      "name": "Prueba 5: Eliminar un libro",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/libros/{{libroId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "libros", "{{libroId}}"]
        }
      }
    },
    {
      "name": "Prueba 6: Crear un usuario",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Juan Pérez\",\n  \"email\": \"juan.perez@ejemplo.com\"\n}"
        },
        "event": [
          {
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "if (pm.response.code === 201) {",
                "  const response = pm.response.json();",
                "  if (response && response.id) {",
                "    pm.collectionVariables.set('usuarioId', response.id);",
                "  }",
                "}"
              ]
            }
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/usuarios",
          "host": ["{{baseUrl}}"],
          "path": ["api", "usuarios"]
        }
      }
    },
    {
      "name": "Prueba 7: Listar todos los usuarios",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/usuarios",
          "host": ["{{baseUrl}}"],
          "path": ["api", "usuarios"]
        }
      }
    },
    {
      "name": "Prueba 8: Consultar un usuario por ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/usuarios/{{usuarioId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "usuarios", "{{usuarioId}}"]
        }
      }
    },
    {
      "name": "Prueba 9: Actualizar un usuario",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Juan Pérez Actualizado\",\n  \"email\": \"juan.perez.actualizado@ejemplo.com\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/usuarios/{{usuarioId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "usuarios", "{{usuarioId}}"]
        }
      }
    },
    {
      "name": "Prueba 10: Eliminar un usuario",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/usuarios/{{usuarioId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "usuarios", "{{usuarioId}}"]
        }
      }
    },
    {
      "name": "Prueba 11: Crear un préstamo",
      "description": "Usa un usuarioId existente y un ejemplarId existente. El backend no expone un endpoint para crear ejemplares.",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"usuarioId\": \"{{usuarioId}}\",\n  \"ejemplarId\": \"{{ejemplarId}}\"\n}"
        },
        "event": [
          {
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "if (pm.response.code === 201) {",
                "  const response = pm.response.json();",
                "  if (response && response.id) {",
                "    pm.collectionVariables.set('prestamoId', response.id);",
                "  }",
                "}"
              ]
            }
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/prestamos",
          "host": ["{{baseUrl}}"],
          "path": ["api", "prestamos"]
        }
      }
    },
    {
      "name": "Prueba 12: Listar todos los préstamos",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/prestamos",
          "host": ["{{baseUrl}}"],
          "path": ["api", "prestamos"]
        }
      }
    },
    {
      "name": "Prueba 13: Consultar un préstamo por ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/prestamos/{{prestamoId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "prestamos", "{{prestamoId}}"]
        }
      }
    },
    {
      "name": "Prueba 14: Registrar devolución de un préstamo",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/prestamos/{{prestamoId}}/devolucion",
          "host": ["{{baseUrl}}"],
          "path": ["api", "prestamos", "{{prestamoId}}", "devolucion"]
        }
      }
    }
  ]
}